# ---- HF Space secrets (Space Settings -> Variables and secrets) ----
# Copy each of these into the Space, filling in real values. Never commit a
# real .env.production — this file is a template only.

NODE_ENV=production
PORT=7860

# Your deployed Vercel URL (no trailing slash). Also used to build the
# password-reset link in auth.service.ts, so it must be the real frontend
# origin, not "*".
CORS_ORIGIN=https://your-app.vercel.app

# ---- Database (Supabase Postgres) ----
# DIRECT_URL: Supabase's `postgres` superuser, via the *direct* (non-pooled)
# connection string (Project Settings -> Database -> Connection string ->
# "Direct connection"). Used for `prisma migrate deploy` and by the backup
# service (pg_dump needs to bypass RLS to get a complete dump).
DIRECT_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# DATABASE_URL: the app's runtime connection, via Supabase's *pooled*
# connection string (Transaction pooler, port 6543), as the low-privilege
# `pharmacy_app` role. That role doesn't exist yet on a fresh Supabase
# project — `prisma migrate deploy` creates it automatically (see the
# `..._rls_location_isolation` migration), with a hardcoded dev password.
#
# SECURITY TODO (defer until you're ready to harden this app — not needed
# to get testing/deployment working today):
#   The `pharmacy_app` role's migration-created password is a public, known
#   dev value ('pharmacy_app_dev_pw') committed in the migration SQL. Anyone
#   who reads the repo knows it. Before this holds real data:
#     1. `ALTER ROLE pharmacy_app PASSWORD '<new-random-password>';` in the
#        Supabase SQL editor.
#     2. Update DATABASE_URL below to match.
#   Until then, treat this deployment as testing-only, not production data.
DATABASE_URL=postgresql://pharmacy_app:pharmacy_app_dev_pw@aws-<region>.pooler.supabase.com:6543/postgres?schema=public

# ---- Auth ----
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ---- Field-level encryption (AES-256-GCM) ----
# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ---- On-demand DB backups (admin console) ----
# pg_dump is installed in Dockerfile.hf and on PATH, so the default works.
PG_DUMP_PATH=pg_dump
# SECURITY/OPS TODO (future): HF Spaces' filesystem is ephemeral — any
# backup written to BACKUP_DIR is lost on the next redeploy/restart. Fine
# for now (testing), but before relying on this for real backups, either
# point BACKUP_DIR at persistent storage or ship backups out (e.g. upload
# to S3/R2) right after creation instead of just downloading on demand.
BACKUP_DIR=backups
